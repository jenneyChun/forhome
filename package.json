{
  "name": "forhome",
  "private": true,
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File server/server.ps1 -Port 8080",
    "dev:local": "powershell -NoProfile -ExecutionPolicy Bypass -File server/server.ps1 -Port 8080",
    "test": "powershell -NoProfile -ExecutionPolicy Bypass -File tests/run-tests.ps1",
    "backup:dry-run": "node scripts/firestore-backup.js --fixture tests/fixtures/backup-state.json --date 2026-06-03 --out-dir log/backup-dry-run",
    "test:e2e": "playwright test -c tests/playwright.config.js",
    "test:e2e:headed": "playwright test -c tests/playwright.config.js --headed"
  },
  "dependencies": {
    "firebase-admin": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest"
  }
}
