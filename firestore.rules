rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function allowedEmail() {
      return request.auth != null
        && request.auth.token.email in [
          'admin@forhome.local',
          'mom@forhome.local',
          'dad@forhome.local',
          'son@forhome.local'
        ];
    }

    function hasMembership(familyId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/families/$(familyId)/memberships/$(request.auth.uid));
    }

    match /families/{familyId}/{document=**} {
      allow read, write: if familyId == 'forhome' && (allowedEmail() || hasMembership(familyId));
    }
  }
}
